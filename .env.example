PROJECT_NAME="Finance Data Processing Backend"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security
# Generate a new string for production (e.g., using `openssl rand -hex 32`)
SECRET_KEY="supersecret_replace_this_in_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# If you use the provided Docker command, the defaults below will work perfectly.
# Otherwise, update the port or credentials to match your local PostgreSQL setup.
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/finance_db"